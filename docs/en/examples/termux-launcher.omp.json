{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "background": "transparent",
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_ON_SURFACE }}"
          ],
          "template": "\u250c"
        },
        {
          "type": "os",
          "style": "plain",
          "background_templates": [
            "{{ .Env.TERMUX_MATERIAL_SURFACE_CONTAINER_HIGHEST }}"
          ],
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_PRIMARY }}"
          ],
          "options": {
            "android": "\uf17b",
            "linux": "\uf17b",
            "macos": "\uf179",
            "ubuntu": "\uf31b",
            "windows": "\ue62a"
          },
          "template": " {{ .Icon }}{{ if .WSL }} (WSL){{ end }}\u2800"
        },
        {
          "type": "shell",
          "style": "plain",
          "background_templates": [
            "{{ .Env.TERMUX_MATERIAL_PRIMARY }}"
          ],
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_ON_PRIMARY }}"
          ],
          "template": " \uf489 {{ .Name }}\u2800"
        },
        {
          "type": "git",
          "style": "plain",
          "background_templates": [
            "{{ .Env.TERMUX_MATERIAL_SECONDARY }}"
          ],
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_ON_SECONDARY }}"
          ],
          "options": {
            "branch_icon": " \ue0a0 ",
            "fetch_status": true
          },
          "template": "{{ .HEAD }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}\u2800"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "background": "transparent",
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_TERTIARY }}"
          ],
          "options": {
            "style": "austin",
            "threshold": 0
          },
          "template": "{{ .FormattedMs }}"
        },
        {
          "type": "time",
          "style": "plain",
          "background": "transparent",
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_ON_SURFACE_VARIANT }}"
          ],
          "options": {
            "time_format": "02/01/06 3:04"
          },
          "template": " \u00b7 {{ dateInZone .Format .CurrentDate \"Asia/Kuwait\" }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "background": "transparent",
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_ON_SURFACE }}"
          ],
          "options": {
            "folder_icon": "\uf07b",
            "folder_separator_template": "<{{ .Env.TERMUX_MATERIAL_PRIMARY }}> \u00bb ",
            "home_icon": "\ueb06",
            "style": "agnoster"
          },
          "template": "\u2514<{{ .Env.TERMUX_MATERIAL_PRIMARY }}>[ {{ .Path }} <{{ .Env.TERMUX_MATERIAL_PRIMARY }}>]"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "status",
          "style": "plain",
          "background": "transparent",
          "foreground_templates": [
            "{{ .Env.TERMUX_MATERIAL_PRIMARY }}",
            "{{ if gt .Code 0 }}{{ .Env.TERMUX_MATERIAL_ERROR }}{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "template": "\u276f"
        }
      ]
    }
  ],
  "console_title_template": "{{ if .Root }}[root] {{ end }}{{ .Shell }} in <{{ .Folder }}>",
  "transient_prompt": {
    "background": "transparent",
    "foreground_templates": [
      "{{ .Env.TERMUX_MATERIAL_PRIMARY }}",
      "{{ if gt .Code 0 }}{{ .Env.TERMUX_MATERIAL_ERROR }}{{ end }}"
    ],
    "template": "{{ .Shell }} \u276f "
  },
  "final_space": true,
  "version": 4
}
